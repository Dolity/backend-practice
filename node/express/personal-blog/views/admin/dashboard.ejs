<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head', { pageTitle: 'Dashboard' }) %>
</head>
<body>
  <%- include('../partials/nav', { isAdmin: true }) %>
  <main class="container">
    <div class="page-header">
      <h1>Dashboard</h1>
      <a href="/admin/articles/new" class="btn">Add Article</a>
    </div>
    <% if (articles.length === 0) { %>
      <p class="muted">No articles yet. <a href="/admin/articles/new">Add your first article</a>.</p>
    <% } else { %>
      <table class="table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Published</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% articles.forEach(function(article) { %>
            <tr>
              <td><a href="/articles/<%= article.slug %>"><%= article.title %></a></td>
              <td><time datetime="<%= article.publishedAt %>"><%= article.publishedAt %></time></td>
              <td class="actions">
                <a href="/admin/articles/<%= article.slug %>/edit" class="btn btn-sm">Edit</a>
                <form action="/admin/articles/<%= article.slug %>/delete" method="post" class="inline-form"
                  onsubmit="return confirm('Delete this article?');">
                  <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </main>
</body>
</html>
